# ─────────────────────────────────────────────
#  Crypto AI Daily Agent — Environment Variables
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# NewsAPI key (get free at https://newsapi.org)
NEWS_API_KEY=newsapi

# AI Backend (gemini or ollama)
AI_BACKEND=gemini

# Google Gemini API key (get free at https://aistudio.google.com)
GEMINI_API_KEY=GEMINI_API_KEY

# Local Ollama configuration (if AI_BACKEND=ollama)
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434

# ── Email Configuration ──────────────────────
# Your Gmail address (used as the sender)
SMTP_EMAIL=youremail@gmail.com

# Gmail App Password (NOT your normal password)
# Generate at: Google Account → Security → 2-Step Verification → App Passwords
SMTP_APP_PASSWORD=SMTP_APP_PASSWORD

# Email address that receives the daily recommendation (can be any email)
RECIPIENT_EMAIL=recipient@gmail.com@example.com

# ── Schedule ─────────────────────────────────
# Time to send the daily email, 24-hour format (HH:MM)
DAILY_RUN_TIME=09:00
